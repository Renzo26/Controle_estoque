# Variáveis usadas pelo docker-compose.yml (configurar no painel do EasyPanel em produção)

# --- Backend ---
# Banco (Supabase Session Pooler, porta 5432, IPv4)
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres
# Supabase Storage (upload de fotos)
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_KEY=<service_role_key>
SUPABASE_BUCKET=produtos
# Origens permitidas no CORS (domínio do frontend em produção)
CORS_ORIGINS=https://estoque.seudominio.com

# --- Frontend (build-time) ---
# URL pública do backend, com sufixo /api. Injetada no build do Vite via build-arg.
VITE_API_URL=https://api-estoque.seudominio.com/api
